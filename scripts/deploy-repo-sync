#!/bin/bash
# Deploy-MCP Skill: Repository Sync & Validate
# Wrapper para sincronização e validação de repositórios

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DB_SCRIPT="$SCRIPT_DIR/db/validate_and_sync_repos.py"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Help
show_help() {
    cat << EOF
${BLUE}╔═══════════════════════════════════════════════════════════════╗${NC}
${BLUE}║        Deploy-MCP: Repository Sync & Validate Skill           ║${NC}
${BLUE}╚═══════════════════════════════════════════════════════════════╝${NC}

USAGE:
    deploy-repo-sync [COMMAND] [OPTIONS]

COMMANDS:
    ${GREEN}validate${NC}       - Validar discrepâncias (somente leitura)
    ${GREEN}reconcile${NC}      - Reconciliar/corrigir problemas
    ${GREEN}sync${NC}           - Sincronizar com GitHub
    ${GREEN}report${NC}         - Gerar relatório detalhado
    ${GREEN}status${NC}         - Mostrar status atual (padrão)
    ${GREEN}help${NC}           - Mostrar esta ajuda

OPTIONS:
    --all              Executar validação + reconciliação + relatório
    --json             Output em JSON
    --quiet            Suprimir output detalhado

EXAMPLES:
    # Apenas validar
    deploy-repo-sync validate

    # Reconciliar problemas
    deploy-repo-sync reconcile

    # Tudo junto
    deploy-repo-sync --all

    # Output JSON para CI/CD
    deploy-repo-sync status --json

EOF
}

# Cores de status
status_ok() { echo -e "${GREEN}✅ $1${NC}"; }
status_warn() { echo -e "${YELLOW}⚠️  $1${NC}"; }
status_error() { echo -e "${RED}❌ $1${NC}"; }
status_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }

# Main
main() {
    local cmd="${1:-status}"
    local arg2="${2:-}"
    local arg3="${3:-}"

    # Verificar Python
    if ! command -v python3 &> /dev/null; then
        status_error "Python3 não encontrado"
        exit 1
    fi

    # Verificar script
    if [ ! -f "$DB_SCRIPT" ]; then
        status_error "Script não encontrado: $DB_SCRIPT"
        exit 1
    fi

    case "$cmd" in
        validate|val)
            status_info "Validando repositórios..."
            python3 "$DB_SCRIPT" --validate
            ;;

        reconcile|rec)
            status_warn "Reconciliando discrepâncias..."
            python3 "$DB_SCRIPT" --reconcile
            status_ok "Reconciliação concluída"
            ;;

        sync)
            status_info "Sincronizando com GitHub..."
            python3 "$DB_SCRIPT" --sync
            status_ok "Sincronização concluída"
            ;;

        report|rep)
            status_info "Gerando relatório..."
            python3 "$DB_SCRIPT" --report
            ;;

        status|stat)
            status_info "Status dos repositórios:"
            python3 "$DB_SCRIPT" --validate
            ;;

        --all)
            status_info "Executando validação + reconciliação + relatório..."
            python3 "$DB_SCRIPT" --all
            status_ok "Processo concluído"
            ;;

        --json)
            # Output JSON para CI/CD
            python3 "$DB_SCRIPT" --validate 2>/dev/null | grep -E "Filesystem|PostgreSQL|GitHub" | \
            jq -R -s 'split("\n") | map(select(. != "")) | {repos: .}'
            ;;

        help|--help|-h)
            show_help
            ;;

        *)
            status_error "Comando desconhecido: $cmd"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# Executa
main "$@"
exit $?
