{
  "name": "frontzilla-pixelfera-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP Server: shared capabilities layer for FrontZilla and PixelFera AI agents",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src tests --ext .ts",
    "format": "eslint src tests --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "zod": "^3.22.0",
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "vitest": "^1.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
